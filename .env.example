# ─── Database ────────────────────────────────────────────────────────────────
DB_URL=postgresql://user:password@host:5432/dbname?sslmode=require
MIGIRATION_PATH=internal/constant/query/schemas

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TG_TOKEN=your_telegram_bot_token
TG_BOT_USERNAME=gabaaBot
TG_WEBHOOK_ENABLED=false
TG_WEBHOOK_SECRET=your_webhook_secret

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=8085

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL=https://gabaa-web.vercel.app

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── LakiPay ─────────────────────────────────────────────────────────────────
LAKIPAY_API_KEY=your_lakipay_api_key
LAKIPAY_BASE_URL=https://api.lakipay.co
LAKIPAY_CALLBACK_URL=https://your-api-host/api/v1/webhook/lakipay
LAKIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
